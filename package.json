{
  "name": "periodic-notes",
  "version": "2.2.0",
  "description": "Create and manage daily, weekly, monthly, and yearly notes",
  "main": "main.js",
  "author": "Mark Ayers (originally by Liam Cain)",
  "license": "MIT",
  "scripts": {
    "audit": "bun audit --audit-level=critical",
    "dev": "vite build --watch",
    "build": "bun run check && vite build",
    "check": "bun run typecheck && biome check . && svelte-check",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "version": "bun run version-bump.ts",
    "test": "bun test",
    "deploy": "bun run deploy.ts"
  },
  "overrides": {
    "devalue": ">=5.6.4"
  },
  "dependencies": {
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "moment": "^2.30.1",
    "obsidian": "^1.13.1",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
